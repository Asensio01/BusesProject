CREATE DATABASE autobuses_db;
USE autobuses_db;

-- Tabla de Usuarios
CREATE TABLE usuarios (
    id_usuario INT AUTO_INCREMENT PRIMARY KEY,
    nombre VARCHAR(50) NOT NULL,
    apellido VARCHAR(50) NOT NULL,
    email VARCHAR(100) UNIQUE NOT NULL,
    password_hash VARCHAR(255) NOT NULL,
    telefono VARCHAR(15) NULL,
    rol ENUM('ADMIN', 'USER') DEFAULT 'USER',
    fecha_ascenso_admin DATE NULL  
);

-- Tabla de Permisos
CREATE TABLE permisos (
    id_permiso INT AUTO_INCREMENT PRIMARY KEY,
    nombre VARCHAR(100) UNIQUE NOT NULL
);

-- Tabla de Relación Usuario - Permisos
CREATE TABLE usuarios_permisos (
    id_usuario INT NOT NULL,
    id_permiso INT NOT NULL,
    PRIMARY KEY (id_usuario, id_permiso),
    FOREIGN KEY (id_usuario) REFERENCES usuarios(id_usuario) ON DELETE CASCADE,
    FOREIGN KEY (id_permiso) REFERENCES permisos(id_permiso) ON DELETE CASCADE
);

-- Tabla de Auditoría (Registro de modificaciones en reservas y rutas)
CREATE TABLE auditorias (
    id_auditoria INT AUTO_INCREMENT PRIMARY KEY,
    id_usuario INT NOT NULL,  -- Quién hizo la modificación
    tabla_modificada ENUM('reservas', 'rutas') NOT NULL,
    id_registro INT NOT NULL,  -- ID de la reserva o ruta modificada
    accion ENUM('CREAR', 'MODIFICAR', 'ELIMINAR') NOT NULL,
    fecha TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY (id_usuario) REFERENCES usuarios(id_usuario) ON DELETE CASCADE
);

-- Tabla de Reservas
CREATE TABLE reservas (
    id_reserva INT AUTO_INCREMENT PRIMARY KEY,
    id_usuario INT NOT NULL,
    localizador VARCHAR(50) UNIQUE NOT NULL,
    fecha_emision DATE NOT NULL,
    ciudad_origen VARCHAR(100) NOT NULL,
    ciudad_destino VARCHAR(100) NOT NULL,
    FOREIGN KEY (id_usuario) REFERENCES usuarios(id_usuario) ON DELETE CASCADE
);

-- Tabla de Tipos de Bus
CREATE TABLE tipos_bus (
    id_tipo INT AUTO_INCREMENT PRIMARY KEY,
    nombre VARCHAR(50) NOT NULL,
    capacidad_maxima INT NOT NULL CHECK (capacidad_maxima > 0)
);

-- Tabla de Autobuses
CREATE TABLE autobuses (
    id_autobus INT AUTO_INCREMENT PRIMARY KEY,
    placa VARCHAR(20) UNIQUE NOT NULL,
    id_tipo INT NOT NULL,
    FOREIGN KEY (id_tipo) REFERENCES tipos_bus(id_tipo) ON DELETE CASCADE
);

-- Tabla de Características de Bus
CREATE TABLE caracteristicas_bus (
    id_caracteristica INT AUTO_INCREMENT PRIMARY KEY,
    nombre VARCHAR(50) NOT NULL UNIQUE
);

-- Relación Autobuses - Características
CREATE TABLE autobuses_caracteristicas (
    id_autobus INT NOT NULL,
    id_caracteristica INT NOT NULL,
    PRIMARY KEY (id_autobus, id_caracteristica),
    FOREIGN KEY (id_autobus) REFERENCES autobuses(id_autobus) ON DELETE CASCADE,
    FOREIGN KEY (id_caracteristica) REFERENCES caracteristicas_bus(id_caracteristica) ON DELETE CASCADE
);

-- Tabla de Rutas
CREATE TABLE rutas (
    id_ruta INT AUTO_INCREMENT PRIMARY KEY,
    nombre_ruta VARCHAR(100) NOT NULL
);

-- Tabla de Tramos
CREATE TABLE tramos (
    id_tramo INT AUTO_INCREMENT PRIMARY KEY,
    ciudad_origen VARCHAR(100) NOT NULL,
    ciudad_destino VARCHAR(100) NOT NULL,
    hora_salida TIME NOT NULL,
    duracion INT NOT NULL CHECK (duracion > 0)
);

-- Relación Rutas - Tramos
CREATE TABLE rutas_tramos (
    id_ruta INT NOT NULL,
    id_tramo INT NOT NULL,
    orden INT NOT NULL CHECK (orden > 0),
    PRIMARY KEY (id_ruta, id_tramo),
    FOREIGN KEY (id_ruta) REFERENCES rutas(id_ruta) ON DELETE CASCADE,
    FOREIGN KEY (id_tramo) REFERENCES tramos(id_tramo) ON DELETE CASCADE
);

-- Tabla de Transbordos (Cambio de Autobuses en un Viaje)
CREATE TABLE transbordos (
    id_transbordo INT AUTO_INCREMENT PRIMARY KEY,
    id_reserva INT NOT NULL,
    id_tramo INT NOT NULL,
    id_autobus INT NOT NULL,
    numero_fila INT NOT NULL CHECK (numero_fila > 0),
    letra_asiento CHAR(1) NOT NULL CHECK (letra_asiento BETWEEN 'A' AND 'Z'),
    FOREIGN KEY (id_reserva) REFERENCES reservas(id_reserva) ON DELETE CASCADE,
    FOREIGN KEY (id_tramo) REFERENCES tramos(id_tramo) ON DELETE CASCADE,
    FOREIGN KEY (id_autobus) REFERENCES autobuses(id_autobus) ON DELETE CASCADE
);
